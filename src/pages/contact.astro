---
import Layout from '../layouts/Layout.astro';
---

<Layout title="お問い合わせ | 渡部かおるピアノ教室" description="渡部かおるピアノ教室へのお問い合わせはこちらのフォームからどうぞ。">
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1 class="page-title">お問い合わせ</h1>
      <p class="page-subtitle">レッスンに関するご質問など、お気軽にどうぞ</p>
    </div>
  </section>

  <!-- Contact Methods -->
  <section class="section contact">
    <div class="container">
      <div class="contact-methods">

        <!-- LINE -->
        <div class="contact-method" id="line" data-fade>
          <div class="method-header method-header--line">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.921 1.558 5.527 4.001 7.245L5 21.5l3.13-1.65C9.3 20.27 10.62 20.5 12 20.5c5.523 0 10-4.145 10-9.257C22 6.145 17.523 2 12 2zm-3.5 11.5h-1.25A.25.25 0 0 1 7 13.25v-4.5A.25.25 0 0 1 7.25 8.5h1.25v5zm1.75 0V8.5h1.25l2 3.25V8.5H14.75v5H13.5l-2-3.25v3.25H10.25zm7 0H15v-5h2.75v1.25h-1.5v.75h1.5V11.5h-1.5v.75h1.5V13.5z"/>
            </svg>
            <h2 class="method-title">LINEでのお問い合わせ</h2>
          </div>
          <div class="method-body">
            <p class="method-desc">LINEからお気軽にメッセージをお送りください。</p>
            <div class="line-qr">
              <img src="/images/qr-line.jpg" alt="LINE QRコード" class="line-qr-img" width="160" height="160" />
            </div>
            <a href="https://lin.ee/tpY9vJf" target="_blank" rel="noopener noreferrer" class="btn btn-line method-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.921 1.558 5.527 4.001 7.245L5 21.5l3.13-1.65C9.3 20.27 10.62 20.5 12 20.5c5.523 0 10-4.145 10-9.257C22 6.145 17.523 2 12 2zm-3.5 11.5h-1.25A.25.25 0 0 1 7 13.25v-4.5A.25.25 0 0 1 7.25 8.5h1.25v5zm1.75 0V8.5h1.25l2 3.25V8.5H14.75v5H13.5l-2-3.25v3.25H10.25zm7 0H15v-5h2.75v1.25h-1.5v.75h1.5V11.5h-1.5v.75h1.5V13.5z"/>
              </svg>
              LINEを開く
            </a>
          </div>
        </div>

        <!-- Divider -->
        <div class="contact-divider" data-fade style="transition-delay:80ms">
          <span>または</span>
        </div>

        <!-- Form -->
        <div class="contact-method" data-fade style="transition-delay:160ms">
          <div class="method-header method-header--form">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <h2 class="method-title">メールフォーム</h2>
          </div>
          <div class="method-body">
            <p class="method-desc">以下のフォームに必要事項をご記入のうえ、送信してください。</p>
            <div class="form-wrap">
        <form id="contact-form" novalidate>
          <div class="form-group">
            <label for="name" class="form-label">お名前 <span class="required">必須</span></label>
            <input type="text" id="name" name="name" class="form-input" required placeholder="山田 花子" />
            <p class="form-error" id="name-error"></p>
          </div>

          <div class="form-group">
            <label for="email" class="form-label">メールアドレス <span class="required">必須</span></label>
            <input type="email" id="email" name="email" class="form-input" required placeholder="example@email.com" />
            <p class="form-error" id="email-error"></p>
          </div>

          <div class="form-group">
            <label for="phone" class="form-label">電話番号</label>
            <input type="tel" id="phone" name="phone" class="form-input" placeholder="090-1234-5678" />
          </div>

          <div class="form-group">
            <label for="message" class="form-label">お問い合わせ内容 <span class="required">必須</span></label>
            <textarea id="message" name="message" class="form-input form-textarea" required rows="6" placeholder="レッスンについてのご質問、体験レッスンのご希望など"></textarea>
            <p class="form-error" id="message-error"></p>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-outline" id="submit-btn">送信する</button>
          </div>
        </form>

        <!-- Success -->
        <div class="form-result success" id="form-success" hidden>
          <div class="result-icon">✓</div>
          <h3 class="result-title">送信完了しました</h3>
          <p class="result-text">
            お問い合わせありがとうございます。<br />
            内容を確認のうえ、折り返しご連絡いたします。
          </p>
        </div>

        <!-- Error -->
        <div class="form-result error" id="form-error" hidden>
          <div class="result-icon">!</div>
          <h3 class="result-title">送信に失敗しました</h3>
          <p class="result-text">
            申し訳ございません。時間を置いて再度お試しください。
          </p>
          <button class="btn btn-outline" id="retry-btn">もう一度試す</button>
        </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background:
      linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)),
      url('/images/catch03.jpg') center / cover no-repeat;
    color: #fff;
  }

  .page-header .page-title {
    color: #fff;
  }

  .page-header .page-subtitle {
    color: rgba(255, 255, 255, 0.8);
  }

  .contact {
    background: var(--color-bg);
  }

  .contact-methods {
    max-width: 640px;
    margin: 0 auto;
  }

  .contact-method {
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 0;
  }

  .method-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 28px;
    color: #fff;
  }

  .method-header--line {
    background: #06C755;
  }

  .method-header--form {
    background-image: url('/images/image-bg-pop.jpg');
    background-size: 800%;
    background-position: 71% 59%;
    background-repeat: no-repeat;
  }

  .method-header--form .method-title,
  .method-header--form svg {
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.5), 0 0 6px rgba(0, 0, 0, 0.3);
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.1));
  }

  .method-title {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .method-body {
    padding: 28px;
    background: #fff;
  }

  .method-desc {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 24px;
    line-height: 1.8;
  }

  .line-qr {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }

  .line-qr-img {
    width: 160px;
    height: 160px;
    border-radius: 8px;
    object-fit: cover;
  }

  .method-btn {
    display: flex;
    width: 100%;
    justify-content: center;
  }

  .contact-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    text-align: center;
    margin: 28px 0;
    color: var(--color-text-light);
    font-size: 0.85rem;
  }

  .contact-divider::before,
  .contact-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .form-wrap {
    max-width: 100%;
  }

  .form-group {
    margin-bottom: 24px;
  }

  .form-label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .required {
    font-size: 0.75rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-left: 4px;
  }

  .form-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: var(--font-family);
    color: var(--color-text);
    background: var(--color-bg);
    transition: border-color 0.2s;
  }

  .form-input::placeholder {
    color: #bbb;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .form-input.invalid {
    border-color: #d94f4f;
  }

  .form-textarea {
    resize: vertical;
    min-height: 140px;
  }

  .form-error {
    font-size: 0.8rem;
    color: #d94f4f;
    margin-top: 6px;
    min-height: 1.2em;
  }

  .form-actions {
    text-align: center;
    margin-top: 32px;
  }

  .form-actions .btn {
    min-width: 200px;
  }

  .form-actions .btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  /* 送信するボタン: テキストに text-bg-pop を適用、ボーダーは薄いグレー */
  .form-actions .btn-outline,
  #retry-btn {
    border-color: var(--color-border);
    background-image: var(--text-bg-pop);
    background-size: 800% 800%;
    background-position: 20% 40%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .form-actions .btn-outline:hover,
  #retry-btn:hover {
    border-color: transparent;
    background-image:
      var(--text-bg-pop),
      linear-gradient(#fff, #fff),
      var(--text-bg-pop);
    background-size: 800% 800%, auto, 400% 400%;
    background-position: 60% 70%, center, 40% 30%;
    background-origin: border-box;
    background-clip: text, padding-box, border-box;
    color: transparent;
  }

  /* Result */
  .form-result {
    text-align: center;
    padding: 48px 24px;
  }

  .result-icon {
    width: 56px;
    height: 56px;
    line-height: 56px;
    border-radius: 50%;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 auto 20px;
  }

  .form-result.success .result-icon {
    background: #e8f5e9;
    color: #43a047;
  }

  .form-result.error .result-icon {
    background: #fce4ec;
    color: #d94f4f;
  }

  .result-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .result-text {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 24px;
    line-height: 1.8;
  }

</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successEl = document.getElementById('form-success')!;
  const errorEl = document.getElementById('form-error')!;
  const retryBtn = document.getElementById('retry-btn')!;

  const API_ENDPOINT = 'https://aa5nai9bpc.execute-api.ap-northeast-1.amazonaws.com//contact';

  function validateField(field: HTMLInputElement | HTMLTextAreaElement): boolean {
    const errorEl = document.getElementById(`${field.id}-error`);
    let message = '';

    if (field.required && !field.value.trim()) {
      message = 'この項目は必須です';
    } else if (field.type === 'email' && field.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value)) {
      message = '正しいメールアドレスを入力してください';
    }

    if (errorEl) errorEl.textContent = message;
    field.classList.toggle('invalid', !!message);
    return !message;
  }

  function validateForm(): boolean {
    const fields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('.form-input[required]');
    let valid = true;
    fields.forEach((field) => {
      if (!validateField(field)) valid = false;
    });
    return valid;
  }

  // Real-time validation
  form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('.form-input').forEach((field) => {
    field.addEventListener('blur', () => validateField(field));
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateForm()) return;

    submitBtn.disabled = true;
    submitBtn.textContent = '送信中...';

    const data = {
      name: (document.getElementById('name') as HTMLInputElement).value.trim(),
      email: (document.getElementById('email') as HTMLInputElement).value.trim(),
      phone: (document.getElementById('phone') as HTMLInputElement).value.trim(),
      message: (document.getElementById('message') as HTMLTextAreaElement).value.trim(),
    };

    try {
      if (!API_ENDPOINT) {
        throw new Error('API endpoint is not configured');
      }
      const res = await fetch(API_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error('Request failed');
      form.hidden = true;
      successEl.hidden = false;
    } catch {
      form.hidden = true;
      errorEl.hidden = false;
    }
  });

  retryBtn.addEventListener('click', () => {
    errorEl.hidden = true;
    form.hidden = false;
    submitBtn.disabled = false;
    submitBtn.textContent = '送信する';
  });
</script>
