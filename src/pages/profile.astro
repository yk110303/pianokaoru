---
import Layout from '../layouts/Layout.astro';
---

<Layout title="プロフィール | 渡部かおるピアノ教室" description="渡部かおるピアノ教室の講師プロフィール。国立音楽大学卒業、PTNA指導会員、松田知育ピアノメソッド認定講師。">
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1 class="page-title">プロフィール</h1>
      <p class="page-subtitle">Profile</p>
    </div>
  </section>

  <!-- Profile -->
  <section class="section profile">
    <div class="container">
      <div class="profile-inner">
        <p class="profile-name">ピアノ講師 渡部 薫</p>
        <ul class="profile-list">
          <li class="profile-item">愛知県立明和高校音楽科 ピアノ専攻卒業</li>
          <li class="profile-item">国立音楽大学音楽学部器楽学科 ピアノ科卒業</li>
          <li class="profile-item">PTNA指導会員</li>
          <li class="profile-item">PSTA指導者</li>
          <li class="profile-item">バスティン研究会講習修了</li>
          <li class="profile-item">松田知育ピアノメソッド認定講師</li>
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background:
      linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)),
      url('/images/classroom01.jpg') center / cover no-repeat;
    color: #fff;
  }

  .page-header .page-title {
    color: #fff;
  }

  .page-header .page-subtitle {
    color: rgba(255, 255, 255, 0.8);
  }

  .profile {
    background: var(--color-bg);
  }

  .profile-inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .profile-name {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 32px;
    color: var(--color-text);
  }

  .profile-list {
    list-style: none;
    text-align: left;
    display: inline-block;
  }

  .profile-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    color: var(--color-text-light);
    padding: 6px 0;
  }

  .profile-item::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }
</style>
