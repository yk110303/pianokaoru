---
const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'トップ' },
  { href: '/lesson', label: 'レッスン案内' },
  { href: '/profile', label: 'プロフィール' },
  { href: '/contact', label: 'お問い合わせ' },
];
---

<div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo">渡部かおるピアノ教室</a>
    <button class="menu-toggle" aria-label="メニューを開く" aria-expanded="false">
      <span class="menu-toggle-bar"></span>
      <span class="menu-toggle-bar"></span>
      <span class="menu-toggle-bar"></span>
    </button>
    <nav class="nav" id="nav">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', { active: currentPath === item.href }]}
            >
              <span class="nav-link-inner">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: transparent;
    z-index: 100;
    transition: padding 0.3s;
  }

  .header.scrolled {
    padding: 20px 20px 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 40px 60px;
    transition: background 0.3s, box-shadow 0.3s, border-radius 0.3s, padding 0.3s;
  }

  .header.scrolled .header-inner {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    padding: 20px 40px;
  }

  .logo {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    background-image:
      linear-gradient(to bottom right, #ffffff 50%, transparent 60px),
      url('/images/image-bg-pop.jpg');
    background-size: 100% 100%, 800% 800%;
    background-position: 0 0, 20% 60%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .header.scrolled .logo {
    background-image:
      linear-gradient(to bottom right, #38342e 50px, transparent 60px),
      url('/images/image-bg-pop.jpg');
  }

  .nav-list {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.9rem;
    font-weight: 500;
    position: relative;
    padding: 4px 0;
    transition: color 0.3s;
  }

  .header.scrolled .nav-link {
    color: var(--color-text-light);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-image: url('/images/image-bg-pop.jpg');
    background-size: 400px 400px;
    transition: width 0.2s;
  }

  li:nth-child(1) .nav-link::after { background-position: 0px 0px; }
  li:nth-child(2) .nav-link::after { background-position: -100px -100px; }
  li:nth-child(3) .nav-link::after { background-position: -200px -200px; }
  li:nth-child(4) .nav-link::after { background-position: -300px -100px; }

  .nav-link:hover,
  .nav-link.active {
    color: #fff;
  }

  .header.scrolled .nav-link:hover,
  .header.scrolled .nav-link.active {
    color: var(--color-text);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .menu-toggle-bar {
    display: block;
    width: 28px;
    height: 2.5px;
    border-radius: 2px;
    background: #fff;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s, background 0.3s;
  }

  .header.scrolled .menu-toggle-bar {
    background: var(--color-text);
  }

  /* ✕ アニメーション（aria-expanded="true" のとき） */
  .menu-toggle[aria-expanded="true"] .menu-toggle-bar:nth-child(1) {
    transform: translateY(8.5px) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle-bar:nth-child(3) {
    transform: translateY(-8.5px) rotate(-45deg);
  }

  .nav-overlay {
    display: none;
  }

  @media (max-width: 768px) {
    .header {
      height: var(--header-height);
    }

    .header.scrolled {
      padding: 0;
    }

    .header-inner {
      height: 100%;
      padding: 0 24px;
    }

    .header.scrolled .header-inner {
      border-radius: 0;
      padding: 0 24px;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(8px);
      box-shadow: 0 1px 12px rgba(0, 0, 0, 0.08);
    }

    .nav-overlay {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.7);
      z-index: 99;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }

    .nav-overlay.open {
      opacity: 1;
      pointer-events: auto;
    }

    .menu-toggle {
      display: flex;
      margin-right: -8px;
    }

    .nav {
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--color-border);
      transform: translateY(-100%);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.3s, opacity 0.3s;
    }

    .nav.open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .nav-list {
      flex-direction: column;
      gap: 0;
      padding: 8px 0;
    }

    .logo {
      font-size: 1.15rem;
    }

    .nav-link {
      display: block;
      padding: 14px 28px;
      font-size: 1rem;
      color: var(--color-text-light);
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--color-accent);
    }

    .nav-link::after {
      display: none;
    }

    .nav-link-inner {
      position: relative;
    }

    .nav-link-inner::after {
      content: '';
      position: absolute;
      bottom: -6px;
      left: 0;
      width: 0;
      height: 2px;
      background-image: url('/images/image-bg-pop.jpg');
      background-size: 400px 400px;
      background-position: -100px -100px;
      transition: width 0.2s;
    }

    .nav-link:hover .nav-link-inner::after,
    .nav-link.active .nav-link-inner::after {
      width: 100%;
    }
  }
</style>

<script>
  // スクロールでヘッダーの色を切り替え
  const header = document.querySelector('.header') as HTMLElement;
  const hero = document.querySelector('.hero') as HTMLElement;

  function updateHeaderState() {
    if (!hero) {
      header?.classList.add('scrolled');
      return;
    }
    const heroBottom = hero.getBoundingClientRect().bottom;
    if (heroBottom <= 0) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', updateHeaderState, { passive: true });
  updateHeaderState();

  const toggle = document.querySelector('.menu-toggle');
  const nav = document.getElementById('nav');
  const overlay = document.getElementById('nav-overlay');

  function openMenu() {
    nav?.classList.add('open');
    overlay?.classList.add('open');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'メニューを閉じる');
    header?.classList.add('scrolled');
  }

  function closeMenu() {
    nav?.classList.remove('open');
    overlay?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'メニューを開く');
    updateHeaderState();
  }

  toggle?.addEventListener('click', () => {
    nav?.classList.contains('open') ? closeMenu() : openMenu();
  });

  overlay?.addEventListener('click', closeMenu);

  // ナビリンクをタップしたら閉じる
  nav?.querySelectorAll('.nav-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
